Options -MultiViews

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /
DirectoryIndex index.html

# Remove index or index.html from the end of URLs
RewriteCond %{THE_REQUEST} \s/+((?:.*?/)?)(?:index(?:\.html)?)(?:[\s?]|$) [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Canonical URLs: redirect explicit .html requests to extensionless paths.
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[\s?]|$) [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Add trailing slash to directories if missing
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# Leave real files and directories alone.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Internally serve matching .html files for extensionless requests.
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>
